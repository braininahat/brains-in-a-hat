#!/usr/bin/env bash
# tmux-to-wezterm shim
# Intercepts tmux commands from Claude Code and translates to wezterm cli.
# Install: ln -sf <this-file> ~/.local/bin/tmux
# Set TMUX=wezterm-shim in ~/.claude/settings.json env block.
#
# When $WEZTERM_PANE is set, translates tmux → wezterm cli.
# When not in WezTerm, passes through to real /usr/bin/tmux.

# Pass through to real tmux if not in WezTerm
if [ -z "${WEZTERM_PANE:-}" ]; then
  exec /usr/bin/tmux "$@"
fi

LOG=".brains_in_a_hat/state/tmux-shim.log"
mkdir -p "$(dirname "$LOG")" 2>/dev/null

# Log every invocation for debugging
echo "[$(date -Iseconds)] tmux $*" >> "$LOG" 2>/dev/null

case "$1" in
  split-window)
    shift
    # Parse tmux split-window flags — extract the command to run
    CMD_ARGS=()
    SKIP_NEXT=false
    while [ $# -gt 0 ]; do
      if $SKIP_NEXT; then
        SKIP_NEXT=false
        shift
        continue
      fi
      case "$1" in
        -h|-v|-d|-P) shift ;;          # ignore direction/detach/print flags
        -p|-l|-t|-F) SKIP_NEXT=true; shift ;;  # skip flag + value
        --) shift; CMD_ARGS=("$@"); break ;;
        -*) shift ;;
        *)  CMD_ARGS=("$@"); break ;;
      esac
    done

    [ ${#CMD_ARGS[@]} -gt 0 ] || exit 0

    # Grid layout: Claude stays leftmost single row.
    # Agents stack up to MAX_ROWS per column, new column on overflow.
    MAX_ROWS=4
    STATE_FILE=".brains_in_a_hat/state/wezterm-grid.json"
    mkdir -p .brains_in_a_hat/state 2>/dev/null

    if [ ! -f "$STATE_FILE" ]; then
      echo '{"cols":[],"count":0}' > "$STATE_FILE"
    fi

    COUNT=$(jq -r '.count' "$STATE_FILE" 2>/dev/null) || COUNT=0
    COL_IDX=$((COUNT / MAX_ROWS))
    ROW_IDX=$((COUNT % MAX_ROWS))

    if [ "$ROW_IDX" -eq 0 ]; then
      # New column: split right
      if [ "$COL_IDX" -eq 0 ]; then
        # First column: split from Claude's pane
        ANCHOR="${WEZTERM_PANE:-0}"
      else
        # Additional columns: split from previous column's anchor
        ANCHOR=$(jq -r ".cols[$((COL_IDX - 1))]" "$STATE_FILE" 2>/dev/null) || ANCHOR="${WEZTERM_PANE:-0}"
      fi
      NEW_PANE=$(wezterm cli split-pane --right --pane-id "$ANCHOR" -- "${CMD_ARGS[@]}" 2>>"$LOG") || exit 0
      if [ -n "${NEW_PANE:-}" ]; then
        jq --argjson idx "$COL_IDX" --argjson pane "$NEW_PANE" \
          '.cols[$idx] = $pane | .count += 1' "$STATE_FILE" > "${STATE_FILE}.tmp" && \
          mv "${STATE_FILE}.tmp" "$STATE_FILE"
      fi
    else
      # Add row: split bottom from column anchor
      ANCHOR=$(jq -r ".cols[$COL_IDX]" "$STATE_FILE" 2>/dev/null) || ANCHOR="${WEZTERM_PANE:-0}"
      NEW_PANE=$(wezterm cli split-pane --bottom --pane-id "$ANCHOR" -- "${CMD_ARGS[@]}" 2>>"$LOG") || exit 0
      if [ -n "${NEW_PANE:-}" ]; then
        jq '.count += 1' "$STATE_FILE" > "${STATE_FILE}.tmp" && \
          mv "${STATE_FILE}.tmp" "$STATE_FILE"
      fi
    fi

    echo "[$(date -Iseconds)] -> grid col=$COL_IDX row=$ROW_IDX anchor=$ANCHOR -> pane ${NEW_PANE:-?}" >> "$LOG" 2>/dev/null

    # Refocus Claude's pane
    wezterm cli activate-pane --pane-id "${WEZTERM_PANE:-0}" 2>/dev/null
    # Output pane ID (tmux prints pane info with -P)
    echo "${NEW_PANE:-}"
    ;;

  display-message)
    # tmux display-message -p '#{pane_count}' — return pane count
    shift
    if echo "$*" | grep -q 'pane_count'; then
      wezterm cli list --format json 2>/dev/null | jq 'length' 2>/dev/null || echo "1"
    elif echo "$*" | grep -q 'window_width'; then
      echo "200"  # reasonable default
    elif echo "$*" | grep -q 'window_height'; then
      echo "50"
    else
      echo ""
    fi
    ;;

  list-panes)
    # Return pane list in tmux-ish format
    wezterm cli list --format json 2>/dev/null | \
      jq -r '.[] | "\(.pane_id): [200x50] [\(.title)]"' 2>/dev/null || echo "0: [200x50]"
    ;;

  select-pane)
    shift
    # -t <pane_id>
    while [ $# -gt 0 ]; do
      case "$1" in
        -t) wezterm cli activate-pane --pane-id "$2" 2>/dev/null; shift 2 ;;
        *) shift ;;
      esac
    done
    ;;

  kill-pane)
    shift
    while [ $# -gt 0 ]; do
      case "$1" in
        -t) wezterm cli kill-pane --pane-id "$2" 2>/dev/null; shift 2 ;;
        *) shift ;;
      esac
    done
    ;;

  has-session|new-session|new-window|send-keys|set-option|rename-window)
    # No-op for commands we don't need
    echo "[$(date -Iseconds)] no-op: tmux $1 $*" >> "$LOG" 2>/dev/null
    ;;

  *)
    echo "[$(date -Iseconds)] unhandled: tmux $*" >> "$LOG" 2>/dev/null
    ;;
esac

exit 0
