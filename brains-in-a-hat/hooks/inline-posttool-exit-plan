#!/usr/bin/env bash
# PostToolUse[ExitPlanMode] inline: emit scribe hint for exiting plan mode.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
source "${SCRIPT_DIR}/lib-common.sh"

LOGFILE="${BIH_HOME}/state/_bootstrap.log"
mkdir -p "$(dirname "$LOGFILE")" 2>/dev/null || true
exec 2>> "$LOGFILE"

INPUT=$(cat)
SID=$(echo "$INPUT" | jq -r '.session_id // empty' 2>/dev/null) || SID=""
[ -n "$SID" ] || exit 0
KEY=$(read_session_key "$SID")
[ -n "$KEY" ] || exit 0
SDIR=$(state_dir "$KEY")
exec 2>> "${SDIR}/hook-debug.log"

ls "${SDIR}"/active.* &>/dev/null || exit 0

printf '{"hookSpecificOutput":{"additionalContext":"SCRIBE: Exited plan mode. SendMessage Gale with the finalized plan, key decisions, and architecture choices. Gale will log under Decisions & Notes / Architecture."}}'
