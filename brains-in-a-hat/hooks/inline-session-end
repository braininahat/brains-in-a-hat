#!/usr/bin/env bash
# SessionEnd inline: write retro-pending=final, snapshot session-state, emit
# the three-way Mira+Reed+Gale spawn instruction with absolute paths.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
source "${SCRIPT_DIR}/lib-common.sh"

LOGFILE="${BIH_HOME}/state/_bootstrap.log"
mkdir -p "$(dirname "$LOGFILE")" 2>/dev/null || true
exec 2>> "$LOGFILE"

INPUT=$(cat)
SID=$(echo "$INPUT" | jq -r '.session_id // empty' 2>/dev/null) || SID=""
[ -n "$SID" ] || exit 0
KEY=$(read_session_key "$SID")
[ -n "$KEY" ] || exit 0
SDIR=$(state_dir "$KEY")
mkdir -p "$SDIR"
exec 2>> "${SDIR}/hook-debug.log"

ls "${SDIR}"/active.* &>/dev/null || exit 0

echo final > "${SDIR}/retro-pending.${SID}"
cp "${SDIR}/session-state.json" "${SDIR}/session-end-snapshot.json" 2>/dev/null || true

VLOG=$(vault_file_for "$KEY" session-log)
MSG="Session ending. Spawn ALL THREE in parallel, fire-and-exit (do NOT wait): (1) SendMessage(to=Gale) to finalize the session chapter at ${VLOG} and run ensure_vault_index ${KEY}. (2) Agent(subagent_type=\"brains-in-a-hat:meta-retro\", name=\"Mira\", model=\"sonnet\", run_in_background=true, prompt=\"mode=final. Read ${SDIR}/session-state.json, ${SDIR}/activity.jsonl, and ${VLOG}. Write the session retro with CODEOWNERS/patterns/workflow maintenance. Call ensure_vault_index ${KEY} after writing. Report a one-line receipt.\"). (3) Agent(subagent_type=\"brains-in-a-hat:session-manager\", name=\"Reed\", model=\"sonnet\", run_in_background=true, prompt=\"mode=persist. Promote ${SDIR}/session-state.json .decisions to vault as ~/.brains_in_a_hat/vault/${KEY}--decision-<slug>.md. Update .brains_in_a_hat/user-preferences.json. Call ensure_vault_index ${KEY} after each write. Do NOT write a retro — that is Mira's job. Report a one-line receipt.\"). Exit after firing all three."

jq -nc --arg m "$MSG" '{hookSpecificOutput:{hookEventName:"SessionEnd",additionalContext:$m}}'
