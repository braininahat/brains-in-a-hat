#!/usr/bin/env bash
#
# session-start — SessionStart hook for the brains-in-a-hat plugin
#
# Purpose:
#   Bootstrap-only. Creates directory structure, starts dashboard,
#   migrates old state. Does NOT inject persona or gather context —
#   that's handled by /assemble when the user opts in.
#
# Outputs: empty (no persona injection)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
VAULT_DIR="${HOME}/.brains_in_a_hat/vault"
STATE_DIR=".brains_in_a_hat/state"
PROJECT_CONFIG=".brains_in_a_hat"

# ── Shared helpers ────────────────────────────────────────────────────

source "${SCRIPT_DIR}/lib-common.sh"

# ── Dashboard auto-start ─────────────────────────────────────────────

dashboard_start() {
  mkdir -p "${STATE_DIR}"
  if ! pgrep -f 'dashboard/server.py' > /dev/null 2>&1; then
    local py_cmd=""
    if command -v uv &>/dev/null; then
      py_cmd="uv run python"
    elif command -v python3 &>/dev/null; then
      py_cmd="python3"
    else
      return 0
    fi
    nohup ${py_cmd} "${PLUGIN_ROOT}/dashboard/server.py" \
      --project-dir "$(pwd)" > "${STATE_DIR}/dashboard.log" 2>&1 &
    local url="" attempts=0
    while [ -z "$url" ] && [ "$attempts" -lt 5 ]; do
      sleep 0.5
      url=$(grep -oP 'http://[^ ]+' "${STATE_DIR}/dashboard.log" 2>/dev/null | head -1)
      attempts=$((attempts + 1))
    done
    # Dashboard URL is logged but NOT auto-opened (can freeze the system)
    # Access manually at the URL in .brains_in_a_hat/state/dashboard.log
  fi
}

# ── Directory bootstrap ──────────────────────────────────────────────

bootstrap_dirs() {
  # Flat Obsidian-native vault — all notes at root, properties for categorization
  mkdir -p "${VAULT_DIR}"
  mkdir -p "${VAULT_DIR}/attachments"

  # Project-local plugin dirs
  mkdir -p "${PROJECT_CONFIG}"
  mkdir -p "${STATE_DIR}"

  # Dashboard note for Obsidian Dataview (at vault root, project-prefixed)
  local project_name
  project_name=$(detect_project_name)
  local dashboard_note="${VAULT_DIR}/${project_name}--dashboard.md"
  if [ ! -f "${dashboard_note}" ]; then
    sed "s/{{project}}/${project_name}/g" "${PLUGIN_ROOT}/vault-templates/dashboard.md" > "${dashboard_note}" 2>/dev/null || true
  fi

  # CODEOWNERS (project-local, committable)
  if [ ! -f "${PROJECT_CONFIG}/CODEOWNERS" ]; then
    cat > "${PROJECT_CONFIG}/CODEOWNERS" << 'CODEOWNERS'
# brains-in-a-hat agent ownership mappings
# Format: <glob-pattern>  <agent-name>
# meta-retro updates this file during retrospectives.

*.qml                qt-qml
*.py                 architect
*.sql                data-schema
*.yml                devops
*.yaml               devops
*.json               data-schema
Dockerfile           packaging
*.spec               packaging
*.AppImage           packaging
*.md                 docs-writer
*.ts                 architect
*.tsx                architect
tests/               testing-strategy
.github/             devops
CODEOWNERS
  fi

  # .gitignore for runtime state
  if [ ! -f "${PROJECT_CONFIG}/.gitignore" ]; then
    cat > "${PROJECT_CONFIG}/.gitignore" << 'GITIGNORE'
state/
GITIGNORE
  fi

  # Obsidian config
  if [ ! -d "${VAULT_DIR}/.obsidian" ]; then
    mkdir -p "${VAULT_DIR}/.obsidian"
    cat > "${VAULT_DIR}/.obsidian/app.json" << 'OBSIDIAN'
{
  "promptDelete": false,
  "alwaysUpdateLinks": true,
  "newLinkFormat": "relative",
  "attachmentFolderPath": "attachments"
}
OBSIDIAN
  fi
}

# ── Migrate old state from .claude/team/ ─────────────────────────────

migrate_old_state() {
  local old_dir=".claude/team"
  [ -d "${old_dir}" ] || return 0

  # Migrate committable config
  [ -f "${old_dir}/CODEOWNERS" ] && [ ! -f "${PROJECT_CONFIG}/CODEOWNERS" ] && \
    mv "${old_dir}/CODEOWNERS" "${PROJECT_CONFIG}/CODEOWNERS"
  [ -f "${old_dir}/domain-config.json" ] && [ ! -f "${PROJECT_CONFIG}/domain-config.json" ] && \
    mv "${old_dir}/domain-config.json" "${PROJECT_CONFIG}/domain-config.json"

  # Migrate runtime state
  for f in activity.jsonl pm-tier; do
    [ -f "${old_dir}/${f}" ] && mv "${old_dir}/${f}" "${STATE_DIR}/${f}" 2>/dev/null || true
  done

  # Clean up old dir if empty
  rmdir "${old_dir}" 2>/dev/null || true
}

# ── Main ─────────────────────────────────────────────────────────────

main() {
  cat > /dev/null  # consume stdin

  # Bootstrap directories
  bootstrap_dirs

  # Migrate old state
  migrate_old_state

  # Clean up stale active flags (PIDs that no longer exist)
  for pidfile in "${STATE_DIR}"/active.*; do
    [ -f "$pidfile" ] || continue
    local pid="${pidfile##*.}"
    kill -0 "$pid" 2>/dev/null || rm -f "$pidfile"
  done
  # Clean up stale missing-skills markers (match active.* cleanup)
  for marker in "${STATE_DIR}"/missing-shown.*; do
    [ -f "$marker" ] || continue
    local pid="${marker##*/missing-shown.}"
    kill -0 "$pid" 2>/dev/null || rm -f "$marker"
  done
  # Clean up stale skills-cache-built markers
  for marker in "${STATE_DIR}"/skills-cache-built.*; do
    [ -f "$marker" ] || continue
    local pid="${marker##*/skills-cache-built.}"
    kill -0 "$pid" 2>/dev/null || rm -f "$marker"
  done
  # Clean up stale wezterm/terminal pane state files
  rm -f "${STATE_DIR}"/wezterm-feed-*.id "${STATE_DIR}"/wezterm-pane-*.id "${STATE_DIR}"/wezterm-cols-*.json 2>/dev/null || true
  # Clean up stale session-state lock (shouldn't persist — safety net)
  rmdir "${STATE_DIR}/session-state.json.lock.d" 2>/dev/null || true
  # Only clear session state if no other session is active
  if ! ls "${STATE_DIR}"/active.* &>/dev/null; then
    rm -f "${STATE_DIR}/session-state.json"
  fi

  # Start dashboard (non-blocking)
  dashboard_start

  # Register project for dashboard multi-project discovery
  local project_name
  project_name=$(detect_project_name)
  local GLOBAL_SESSIONS="${HOME}/.brains_in_a_hat/active-sessions.jsonl"
  jq -nc \
    --arg ts "$(date -Iseconds)" \
    --arg project "$(pwd)" \
    --arg name "${project_name}" \
    '{ts:$ts, project:$project, name:$name}' >> "${GLOBAL_SESSIONS}"

  # No output — no persona injection.
  # User activates team mode with /assemble.
}

main
