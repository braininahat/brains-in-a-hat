#!/usr/bin/env bash
#
# session-start — SessionStart hook for the brains-in-a-hat plugin
#
# Purpose:
#   Bootstrap-only. Computes the project KEY from cwd, writes the SID→key
#   lookup, creates per-key state and global vault dirs, cleans stale
#   markers, and (if the session source is compaction) writes the
#   compact-pending marker so first-prompt-greeting will emit the recovery
#   banner. Does NOT inject persona or gather context — that's /assemble.
#
# Outputs: empty (no persona injection)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PROJECT_CONFIG=".brains_in_a_hat"   # in-tree, committable only

source "${SCRIPT_DIR}/lib-common.sh"

# Self-redirect stderr to bootstrap log (key not yet known)
LOGFILE="${BIH_HOME}/state/_bootstrap.log"
mkdir -p "$(dirname "$LOGFILE")" 2>/dev/null || true
exec 2>> "$LOGFILE"

# ── Directory bootstrap ──────────────────────────────────────────────

bootstrap_dirs() {
  local key="$1"
  local sdir vdir
  sdir=$(state_dir "${key}")
  vdir="${VAULT_DIR}"

  mkdir -p "${VAULT_DIR}" "${VAULT_DIR}/attachments" "${SESSIONS_DIR}" "${sdir}"

  # In-tree committable config (NOT state — state is now under sdir)
  mkdir -p "${PROJECT_CONFIG}"

  if [ ! -f "${PROJECT_CONFIG}/CODEOWNERS" ]; then
    cat > "${PROJECT_CONFIG}/CODEOWNERS" << 'CODEOWNERS'
# brains-in-a-hat agent ownership mappings
# Format: <glob-pattern>  <agent-name>
# meta-retro updates this file during retrospectives.

*.qml                qt-qml
*.py                 architect
*.sql                data-schema
*.yml                devops
*.yaml               devops
*.json               data-schema
Dockerfile           packaging
*.spec               packaging
*.AppImage           packaging
*.md                 docs-writer
*.ts                 architect
*.tsx                architect
tests/               testing-strategy
.github/             devops
CODEOWNERS
  fi

  if [ ! -f "${PROJECT_CONFIG}/.gitignore" ]; then
    cat > "${PROJECT_CONFIG}/.gitignore" << 'GITIGNORE'
# State moved to ~/.brains_in_a_hat/state/<KEY>/ in v0.7+
# Anything still under state/ here is a pre-migration leftover.
state/
GITIGNORE
  fi

  if [ ! -d "${VAULT_DIR}/.obsidian" ]; then
    mkdir -p "${VAULT_DIR}/.obsidian"
    cat > "${VAULT_DIR}/.obsidian/app.json" << 'OBSIDIAN'
{
  "promptDelete": false,
  "alwaysUpdateLinks": true,
  "newLinkFormat": "relative",
  "attachmentFolderPath": "attachments"
}
OBSIDIAN
  fi
}

# ── Migrate ancient .claude/team/ layout (very old plugin versions) ──

migrate_old_state() {
  local sdir="$1"
  local old_dir=".claude/team"
  [ -d "${old_dir}" ] || return 0

  [ -f "${old_dir}/CODEOWNERS" ] && [ ! -f "${PROJECT_CONFIG}/CODEOWNERS" ] && \
    mv "${old_dir}/CODEOWNERS" "${PROJECT_CONFIG}/CODEOWNERS" 2>/dev/null || true
  [ -f "${old_dir}/domain-config.json" ] && [ ! -f "${PROJECT_CONFIG}/domain-config.json" ] && \
    mv "${old_dir}/domain-config.json" "${PROJECT_CONFIG}/domain-config.json" 2>/dev/null || true

  for f in activity.jsonl pm-tier; do
    [ -f "${old_dir}/${f}" ] && mv "${old_dir}/${f}" "${sdir}/${f}" 2>/dev/null || true
  done

  rmdir "${old_dir}" 2>/dev/null || true
}

# ── Legacy in-tree state detection (informational) ───────────────────

detect_legacy_state() {
  [ -d ".brains_in_a_hat/state" ] || return 0
  if [ -n "$(ls -A .brains_in_a_hat/state 2>/dev/null)" ]; then
    echo "[brains-in-a-hat] Deprecation: in-tree .brains_in_a_hat/state/ exists." >&2
    echo "[brains-in-a-hat]   Run ${PLUGIN_ROOT}/bin/migrate-state-layout.sh to move it under ~/.brains_in_a_hat/state/<KEY>/." >&2
  fi
}

# ── Cleanup stale markers in this session's state dir ────────────────
# All markers are now keyed by SID (Claude Code session UUID), not PID.
# Any marker whose SID doesn't match the current one is stale.

cleanup_state_dir() {
  local sdir="$1" sid="$2"
  local marker prefix

  for prefix in active missing-shown skills-cache-built gather-context-emitted post-mortem-emitted compact-pending; do
    for marker in "${sdir}/${prefix}".*; do
      [ -f "$marker" ] || continue
      [ "${marker##*/${prefix}.}" = "$sid" ] || rm -f "$marker"
    done
  done

  # in-subagent markers — no subagent can be running at session start
  rm -f "${sdir}"/in-subagent.* 2>/dev/null || true

  # Stale lock dirs (safety net — process holding the lock is gone)
  rmdir "${sdir}/session-state.json.lock.d" 2>/dev/null || true
  rmdir "${sdir}/retro.lock.d" 2>/dev/null || true

  # Orphaned dashboard.log from older plugin versions
  rm -f "${sdir}/dashboard.log" 2>/dev/null || true

  # Only clear session state if no other session is active
  if ! ls "${sdir}"/active.* &>/dev/null; then
    rm -f "${sdir}/session-state.json"
  fi
}

# ── Main ─────────────────────────────────────────────────────────────

main() {
  local INPUT SOURCE SID KEY
  INPUT=$(cat)
  SOURCE=$(echo "$INPUT" | jq -r '.source // empty' 2>/dev/null) || SOURCE=""
  SID=$(echo "$INPUT" | jq -r '.session_id // empty' 2>/dev/null) || SID=""

  KEY=$(detect_project_key)
  bootstrap_dirs "${KEY}"

  local SDIR
  SDIR=$(state_dir "${KEY}")

  # From here on, log to per-key debug log
  exec 2>> "${SDIR}/hook-debug.log"

  # Write the SID → key lookup (the linchpin of every other hook)
  if [ -n "${SID}" ]; then
    local f="${SESSIONS_DIR}/${SID}.key"
    printf '%s' "${KEY}" > "${f}.tmp.$$" && mv "${f}.tmp.$$" "${f}"
  fi

  # Cache team name for /assemble
  team_name_for_key "${KEY}" > "${SDIR}/team-name"

  detect_legacy_state
  migrate_old_state "${SDIR}"
  cleanup_state_dir "${SDIR}" "${SID}"

  # Belt + suspenders: if Claude Code is starting from a compaction event,
  # write the compact-pending marker so first-prompt-greeting emits the
  # COMPACTION RECOVERY banner on the next user prompt.
  if [ "$SOURCE" = "compact" ] && [ -n "$SID" ]; then
    touch "${SDIR}/compact-pending.${SID}"
  fi

  # Append to global active-sessions.jsonl
  if [ -n "${SID}" ]; then
    local root name
    root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
    name=$(detect_project_name)
    jq -nc --arg ts "$(date -Iseconds)" \
           --arg project "${root}" \
           --arg key "${KEY}" \
           --arg name "${name}" \
           --arg sid "${SID}" \
      '{ts:$ts,project:$project,key:$key,name:$name,session_id:$sid}' \
      >> "${BIH_HOME}/active-sessions.jsonl" 2>/dev/null || true
  fi

  # No output — no persona injection. User activates team mode with /assemble.
}

main
