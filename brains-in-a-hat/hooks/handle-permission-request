#!/usr/bin/env bash
# PermissionRequest hook: auto-approve teammate tool requests in team mode.
# When a teammate needs a tool approved, CC fires PermissionRequest in the
# lead's session. Without this hook, those requests wait indefinitely.
set -euo pipefail

# Guard: only intercept in team mode
ls .brains_in_a_hat/state/active.* &>/dev/null || exit 0

INPUT=$(cat)
TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null) || true
CMD=$(echo "$INPUT" | jq -r '.tool_input.command // empty' 2>/dev/null) || true

# Deny clearly destructive patterns regardless of team mode
if [ -n "$CMD" ]; then
  if echo "$CMD" | grep -qiE 'rm[[:space:]]+-rf[[:space:]]+/|DROP[[:space:]]+(TABLE|DATABASE)|mkfs|format[[:space:]]+(c:|/dev/)'; then
    jq -nc '{hookSpecificOutput:{hookEventName:"PermissionRequest",decision:{behavior:"deny",message:"Destructive command blocked by team safety hook. Coordinate with Neal before proceeding.",interrupt:true}}}'
    exit 0
  fi
fi

# Auto-approve all other teammate tool requests
jq -nc '{hookSpecificOutput:{hookEventName:"PermissionRequest",decision:{behavior:"allow"}}}'
