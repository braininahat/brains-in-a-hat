#!/usr/bin/env bash
# pretool-agent-check — PreToolUse[Agent] hook
# 1. Guard: no-op if team mode is not active
# 2. Vault check: block spawn if prior research exists in vault
# 3. Model heuristic: advise cheaper model if task looks mechanical
set -euo pipefail

# ── Guard: team mode must be active ──────────────────────────────────
ls .brains_in_a_hat/state/active.* &>/dev/null || exit 0

INPUT=$(cat)
PROMPT=$(echo "$INPUT" | jq -r '.tool_input.prompt // empty' 2>/dev/null) || exit 0
MODEL=$(echo "$INPUT" | jq -r '.tool_input.model // empty' 2>/dev/null) || true
DESC=$(echo "$INPUT" | jq -r '.tool_input.description // empty' 2>/dev/null) || true

VAULT_DIR="${BRAINS_VAULT_DIR:-${HOME}/.brains_in_a_hat/vault}"
PROJECT=$(gh repo view --json name -q '.name' 2>/dev/null || basename "$(pwd)")

# ── Vault Check (project-scoped + global wiki) ──────────────────────

vault_check() {
  [ -d "$VAULT_DIR" ] || return 0
  [ -n "$PROMPT" ] || return 0

  # Exempt infrastructure agents — they're not doing research
  local agent_type
  agent_type=$(echo "$INPUT" | jq -r '.tool_input.subagent_type // empty' 2>/dev/null) || true
  # All brains-in-a-hat team agents skip vault check — it's for gating
  # generic Explore/research spawns, not team member dispatches
  echo "$agent_type" | grep -q '^brains-in-a-hat:' && return 0

  # Bypass: if prompt explicitly declares vault was reviewed, skip check
  echo "$PROMPT" | grep -qF '[vault-reviewed]' && return 0

  # Stopwords: common English + agent prompt boilerplate + generic technical terms
  local stopwords="the a an is are was were be been being have has had do does did will would shall should may might can could of in to for on with at by from as into through during before after above below between your you this that these those it its and or but not no nor so yet also very just only even still already when what which who whom how where why each every all any few more most other some such than too much many well here there then now team hatbrains agent role task rules findings neal sendmessage spawn spawned message report completed work done active mode plan read write edit using use used make keep send via research code data model system project file feature config class function method check based type name output input new should need current state"

  # Extract top 8 keywords from prompt (frequency-ranked, non-stopwords)
  local keywords
  keywords=$(echo "$PROMPT" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alpha:]' '\n' | \
    grep -vxFf <(printf '%s\n' $stopwords) 2>/dev/null | \
    sort | uniq -c | sort -rn | awk '{print $2}' | head -8) || true

  [ -n "$keywords" ] || return 0

  # Build OR pattern for fast first-pass
  local pattern
  pattern=$(echo "$keywords" | tr '\n' '|' | sed 's/|$//')
  [ -n "$pattern" ] || return 0

  # Search entire vault (flat structure — all notes at root)
  # First pass: find files matching any keyword
  local candidates
  candidates=$(grep -rl -iE "$pattern" "$VAULT_DIR" --include='*.md' 2>/dev/null) || true
  [ -n "$candidates" ] || return 0

  # Second pass: require 3+ distinct keyword matches per file
  local matched_files=""
  while IFS= read -r file; do
    [ -f "$file" ] || continue
    local hits=0
    for kw in $keywords; do
      grep -qil "$kw" "$file" 2>/dev/null && hits=$((hits + 1))
    done
    [ "$hits" -ge 3 ] && matched_files="${matched_files}${file}"$'\n'
  done <<< "$candidates"

  matched_files=$(echo "$matched_files" | sed '/^$/d')
  if [ -n "$matched_files" ]; then
    local file_list
    file_list=$(echo "$matched_files" | head -5 | tr '\n' ', ' | sed 's/, $//')
    # Advisory only — no longer blocks. Emit a hint as additionalContext so
    # the spawned agent can choose to read the cited files. Add [vault-reviewed]
    # to prompts to suppress this hint in future spawns.
    local hint="VAULT HINT: Prior research found in the vault at ${file_list}. Read these before or during work if relevant. Add [vault-reviewed] to the prompt to suppress this hint in future spawns."
    jq -nc --arg h "$hint" '{hookSpecificOutput:{hookEventName:"PreToolUse",additionalContext:$h}}'
    exit 0
  fi
}

# ── Model Tier Heuristic ─────────────────────────────────────────────

model_check() {
  local text
  text=$(echo "$DESC $PROMPT" | tr '[:upper:]' '[:lower:]')
  [ -n "$text" ] || return 0

  # Count keyword signals per tier
  local haiku_score=0 sonnet_score=0 opus_score=0
  local haiku_kws="" sonnet_kws=""

  for sig in check verify list grep find exists lookup count; do
    if echo "$text" | grep -qw "$sig" 2>/dev/null; then
      haiku_score=$((haiku_score + 1))
      haiku_kws="$haiku_kws $sig"
    fi
  done

  for sig in review write update test document summarize report audit; do
    if echo "$text" | grep -qw "$sig" 2>/dev/null; then
      sonnet_score=$((sonnet_score + 1))
      sonnet_kws="$sonnet_kws $sig"
    fi
  done

  for sig in design investigate compare analyze architect diagnose debug tradeoff evaluate; do
    echo "$text" | grep -qw "$sig" 2>/dev/null && opus_score=$((opus_score + 1))
  done

  # Determine suggested tier (highest score wins; ties go cheaper)
  local suggested="" matched_kws=""
  if [ "$haiku_score" -gt "$sonnet_score" ] && [ "$haiku_score" -gt "$opus_score" ] && [ "$haiku_score" -gt 0 ]; then
    suggested="haiku"; matched_kws=$(echo "$haiku_kws" | xargs)
  elif [ "$sonnet_score" -gt "$opus_score" ] && [ "$sonnet_score" -gt 0 ]; then
    suggested="sonnet"; matched_kws=$(echo "$sonnet_kws" | xargs)
  fi
  # If opus wins or no clear signal, no advisory needed
  [ -n "$suggested" ] || return 0

  # Map model to cost level (default=opus=3 when unspecified)
  local model_cost=3
  case "${MODEL:-opus}" in
    haiku*) model_cost=1 ;; sonnet*) model_cost=2 ;; opus*) model_cost=3 ;;
  esac

  local suggested_cost=0
  case "$suggested" in
    haiku) suggested_cost=1 ;; sonnet) suggested_cost=2 ;;
  esac

  # Only advise if model is more expensive than suggested
  if [ "$model_cost" -gt "$suggested_cost" ] && [ "$suggested_cost" -gt 0 ]; then
    local actual="${MODEL:-opus(default)}"
    local hint="MODEL HINT: This task looks ${suggested}-tier (keywords: ${matched_kws}). Consider model=\"${suggested}\" instead of ${actual} to save tokens."
    jq -nc --arg h "$hint" '{hookSpecificOutput:{hookEventName:"PreToolUse",additionalContext:$h}}'
    exit 0
  fi
}

# ── Opus Gate ───────────────────────────────────────────────────────

sonnet_ceiling() {
  local agent_type
  agent_type=$(echo "$INPUT" | jq -r '.tool_input.subagent_type // empty' 2>/dev/null) || true

  # Only enforce for brains-in-a-hat team members
  echo "$agent_type" | grep -q '^brains-in-a-hat:' || return 0

  # Opus permitted when spawn prompt contains [opus-justified] tag
  case "${MODEL:-}" in
    opus*)
      echo "$PROMPT" | grep -qF '[opus-justified]' && return 0
      jq -nc --arg r "Opus ceiling: team members run haiku (default) or sonnet. Add [opus-justified] to the spawn prompt to escalate to opus for factually demanding tasks." '{decision:"block",reason:$r}'
      exit 0
      ;;
  esac
}

# ── Explore Vault Hint (advisory) ───────────────────────────────────

explore_vault_hint() {
  local agent_type
  agent_type=$(echo "$INPUT" | jq -r '.tool_input.subagent_type // empty' 2>/dev/null) || true

  # Only target generic Explore agents
  [ "$agent_type" = "Explore" ] || return 0

  VAULT_DIR="${VAULT_DIR:-${HOME}/.brains_in_a_hat/vault}"
  [ -d "$VAULT_DIR" ] || return 0
  [ -n "$PROMPT" ] || return 0

  # Skip if prompt already declares vault reviewed
  echo "$PROMPT" | grep -qF '[vault-reviewed]' && return 0

  # Extract a few salient keywords from the prompt
  local stopwords="the a an is are was were be been being have has had do does did will would shall should may might can could of in to for on with at by from as into through during before after above below between your you this that these those it its and or but not no nor so yet also very just only even still already when what which who whom how where why each every all any few more most other some such than too much many well here there then now code file files find search look explore how does work codebase quickly"
  local keywords
  keywords=$(echo "$PROMPT" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alpha:]' '\n' | \
    grep -vxFf <(printf '%s\n' $stopwords) 2>/dev/null | \
    sort | uniq -c | sort -rn | awk '{print $2}' | head -6) || true
  [ -n "$keywords" ] || return 0

  local pattern
  pattern=$(echo "$keywords" | tr '\n' '|' | sed 's/|$//')
  [ -n "$pattern" ] || return 0

  # Look for vault files matching at least 2 keywords
  local candidates
  candidates=$(grep -rl -iE "$pattern" "$VAULT_DIR" --include='*.md' 2>/dev/null) || true
  [ -n "$candidates" ] || return 0

  local matched_files=""
  while IFS= read -r file; do
    [ -f "$file" ] || continue
    local hits=0
    for kw in $keywords; do
      grep -qil "$kw" "$file" 2>/dev/null && hits=$((hits + 1))
    done
    [ "$hits" -ge 2 ] && matched_files="${matched_files}${file}"$'\n'
  done <<< "$candidates"

  matched_files=$(echo "$matched_files" | sed '/^$/d')
  if [ -n "$matched_files" ]; then
    local file_list
    file_list=$(echo "$matched_files" | head -5 | tr '\n' ', ' | sed 's/, $//')
    local hint="VAULT HINT: Before exploring locally, check these vault notes which may already cover this topic: ${file_list}. Add [vault-reviewed] to the prompt to suppress this hint."
    jq -nc --arg h "$hint" '{hookSpecificOutput:{hookEventName:"PreToolUse",additionalContext:$h}}'
    exit 0
  fi
}

# ── Main ─────────────────────────────────────────────────────────────

sonnet_ceiling
explore_vault_hint
vault_check
model_check
# No ceiling violation, no vault match, no model mismatch — allow silently
