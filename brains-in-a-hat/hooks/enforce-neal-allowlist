#!/usr/bin/env bash
# PreToolUse hook: enforce Neal's tool allowlist in team mode.
# Only the parent session (team lead) is restricted; subagents are
# unrestricted. Subagent detection is via per-key in-subagent.<id>
# marker files written by SubagentStart and removed by SubagentStop.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
source "${SCRIPT_DIR}/lib-common.sh"

LOGFILE="${BIH_HOME}/state/_bootstrap.log"
mkdir -p "$(dirname "$LOGFILE")" 2>/dev/null || true
exec 2>> "$LOGFILE"

INPUT=$(cat)
SID=$(echo "$INPUT" | jq -r '.session_id // empty' 2>/dev/null) || SID=""
[ -n "$SID" ] || exit 0
KEY=$(read_session_key "$SID")
[ -n "$KEY" ] || exit 0
SDIR=$(state_dir "$KEY")
exec 2>> "${SDIR}/hook-debug.log"

# Guard: team mode must be active for THIS session's key
ls "${SDIR}"/active.* &>/dev/null || exit 0

TRANSCRIPT=$(echo "$INPUT" | jq -r '.transcript_path // empty' 2>/dev/null) || exit 0
TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null) || exit 0

# === Subagent detection ===========================================
# Primary: SubagentStart writes ${SDIR}/in-subagent.<id>;
# SubagentStop removes it. If any marker exists in this session's key
# dir, we are inside a subagent context — allow all tools.
if ls "${SDIR}"/in-subagent.* &>/dev/null; then
  exit 0
fi
# Legacy fallback (kept harmless): old transcript_path heuristic.
# transcript_path passed to PreToolUse refers to the PARENT session in
# current Claude Code, so this branch never matches in practice — but
# it is kept in case a future SDK version changes the contract.
if echo "$TRANSCRIPT" | grep -qE '/subagents/agent-[^/]+'; then
  exit 0
fi

# Parent session (Neal) — check allowlist
case "$TOOL" in
  # Read the codebase
  Read|Grep|Glob|LS)
    exit 0 ;;
  # Delegate work
  Agent|SendMessage)
    exit 0 ;;
  # Task management
  TaskCreate|TaskUpdate|TaskList|TaskGet|TaskOutput|TaskStop)
    exit 0 ;;
  # Team management
  TeamCreate|TeamDelete)
    exit 0 ;;
  # User communication
  AskUserQuestion)
    exit 0 ;;
  # Mode management
  EnterPlanMode|ExitPlanMode)
    exit 0 ;;
  # System tools
  ToolSearch|Skill)
    exit 0 ;;
  # Bash: plugin infrastructure + curated read-only commands
  Bash)
    CMD=$(echo "$INPUT" | jq -r '.tool_input.command // empty' 2>/dev/null) || true

    # (a) Plugin infrastructure commands (hooks and skills scripts)
    if echo "$CMD" | grep -qE '/brains-in-a-hat/(hooks|skills)/|\.claude/plugins/.+/(hooks|skills)/'; then
      exit 0
    fi

    # (b) Read-only allowlist — first reject any shell metacharacters
    #     to prevent command chaining, redirection, substitution, pipes,
    #     backgrounding, or process substitution. MUST run before the
    #     prefix match so `gh project list; rm -rf ~` is blocked.
    if echo "$CMD" | LC_ALL=C grep -qE '[;&|<>`$(){}\\]|>>|<<|--exec|-exec'; then
      :  # has metacharacters → fall through to block
    else
      # (c) Anchored prefix allowlist for safe read-only binaries.
      if echo "$CMD" | LC_ALL=C grep -qE '^[[:space:]]*(gh[[:space:]]+(project|repo|issue|pr|api|auth|search)[[:space:]]+(list|view|item-list|get|status|diff|checks|search)([[:space:]]+[-A-Za-z0-9_./=:,@#]+)*[[:space:]]*|git[[:space:]]+(log|status|diff|show|branch|remote|rev-parse|ls-files|ls-tree|describe|tag|for-each-ref|blame|shortlog|reflog[[:space:]]+show|worktree[[:space:]]+list|config[[:space:]]+--get)([[:space:]]+[-A-Za-z0-9_./=:,@#~^]+)*[[:space:]]*|ls([[:space:]]+-[lAah]+)?([[:space:]]+[-A-Za-z0-9_./]+)*[[:space:]]*|pwd[[:space:]]*|whoami[[:space:]]*|date([[:space:]]+[-+%A-Za-z0-9:_ ]+)?[[:space:]]*|cat[[:space:]]+[-A-Za-z0-9_./]+([[:space:]]+[-A-Za-z0-9_./]+)*[[:space:]]*|head([[:space:]]+-n[[:space:]]*[0-9]+)?[[:space:]]+[-A-Za-z0-9_./]+[[:space:]]*|tail([[:space:]]+-n[[:space:]]*[0-9]+)?[[:space:]]+[-A-Za-z0-9_./]+[[:space:]]*|wc([[:space:]]+-[lcw]+)?[[:space:]]+[-A-Za-z0-9_./]+[[:space:]]*|file[[:space:]]+[-A-Za-z0-9_./]+[[:space:]]*)$'; then
        exit 0
      fi
    fi
    ;;
  # Write/Edit: allow plan files (plan mode needs these)
  Write|Edit)
    FILE=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null) || true
    if echo "$FILE" | grep -q '\.claude/plans/'; then
      exit 0
    fi
    ;;
esac

# Block with routing suggestion
case "$TOOL" in
  Write|Edit|NotebookEdit)
    SUGGEST="Paige (docs-writer) for docs, Mason (architect) for code, Gale (scribe) for session log" ;;
  Bash)
    SUGGEST="Porter (devops) for git/CI, Chase (qa-engineer) for tests, Reed (session-manager) for state persistence" ;;
  WebSearch|WebFetch)
    SUGGEST="Hunter (researcher) for web research" ;;
  *)
    SUGGEST="the appropriate specialist agent" ;;
esac

REASON="Team lead can only read, manage tasks, and delegate. Route ${TOOL} to ${SUGGEST}."
jq -nc --arg r "$REASON" '{decision:"block", reason:$r}'
exit 0
