#!/usr/bin/env bash
# Append an in-session decision to session-state.json's decisions array.
# Usage:
#   record-decision "don't touch the auth module"
#   echo "use pattern Y" | record-decision
# Safe under concurrent sessions (directory-based lock).
set -euo pipefail

# Only record when team is active
ls .brains_in_a_hat/state/active.* &>/dev/null || { echo "record-decision: team not active" >&2; exit 1; }

# Read decision text: prefer argv, fall back to stdin
if [ $# -gt 0 ]; then
  TEXT="$*"
else
  TEXT=$(cat)
fi
TEXT=$(echo "$TEXT" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')  # trim
[ -z "$TEXT" ] && { echo "record-decision: empty decision" >&2; exit 1; }

STATE=".brains_in_a_hat/state/session-state.json"
LOCK="${STATE}.lock.d"

# Acquire lock
acquired=0
for _ in 1 2 3 4 5; do
  if mkdir "$LOCK" 2>/dev/null; then acquired=1; break; fi
  sleep 0.1
done
[ "$acquired" = "1" ] || { echo "record-decision: couldn't acquire lock" >&2; exit 1; }
trap 'rmdir "$LOCK" 2>/dev/null || true' EXIT

# Initialize state file if absent
[ -f "$STATE" ] || echo '{"spawned_agents":[],"decisions":[],"last_updated":""}' > "$STATE"

# Append decision with timestamp
jq --arg text "$TEXT" --arg ts "$(date -Iseconds)" \
  '.decisions += [{ts:$ts, text:$text}] | .last_updated = $ts' \
  "$STATE" > "${STATE}.tmp.$$" && mv "${STATE}.tmp.$$" "$STATE"

echo "recorded: $TEXT"
exit 0
