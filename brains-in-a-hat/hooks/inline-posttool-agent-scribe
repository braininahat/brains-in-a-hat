#!/usr/bin/env bash
# PostToolUse[Agent] inline: emit scribe hint after agent completes.
# Skipped when the completing agent IS Gale (avoid recursive prompts).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
source "${SCRIPT_DIR}/lib-common.sh"

LOGFILE="${BIH_HOME}/state/_bootstrap.log"
mkdir -p "$(dirname "$LOGFILE")" 2>/dev/null || true
exec 2>> "$LOGFILE"

INPUT=$(cat)
SID=$(echo "$INPUT" | jq -r '.session_id // empty' 2>/dev/null) || SID=""
[ -n "$SID" ] || exit 0
KEY=$(read_session_key "$SID")
[ -n "$KEY" ] || exit 0
SDIR=$(state_dir "$KEY")
exec 2>> "${SDIR}/hook-debug.log"

ls "${SDIR}"/active.* &>/dev/null || exit 0

AGENT=$(echo "$INPUT" | jq -r '.tool_input.name // .tool_input.subagent_type // "agent"' 2>/dev/null) || AGENT=""
case "$AGENT" in
  Gale|brains-in-a-hat:scribe) exit 0 ;;
esac

printf '{"hookSpecificOutput":{"additionalContext":"SCRIBE: Agent %s just completed. SendMessage Gale with a summary of findings, decisions, metrics, or concepts worth logging. Gale will update the session log, create wiki entries, and curate shared context in session-state.json."}}' "$AGENT"
