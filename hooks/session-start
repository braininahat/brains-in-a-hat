#!/usr/bin/env bash
# SessionStart hook for brains-in-a-hat plugin
# Reads Neal persona, gathers project state, launches dashboard.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
VAULT_DIR="${HOME}/.claude/vault"
TEAM_DIR=".claude/team"

# ── Dashboard auto-start ─────────────────────────────────────────────

dashboard_start() {
  mkdir -p "${TEAM_DIR}"
  if ! pgrep -f 'dashboard/server.py' > /dev/null 2>&1; then
    # Prefer uv, fall back to python3
    local py_cmd=""
    if command -v uv &>/dev/null; then
      py_cmd="uv run python"
    elif command -v python3 &>/dev/null; then
      py_cmd="python3"
    else
      return 0  # No python available, skip dashboard
    fi
    nohup ${py_cmd} "${PLUGIN_ROOT}/dashboard/server.py" \
      --project-dir "$(pwd)" > "${TEAM_DIR}/dashboard.log" 2>&1 &
    sleep 1
    local url
    url=$(grep -oP 'http://[^ ]+' "${TEAM_DIR}/dashboard.log" 2>/dev/null | head -1)
    if [ -n "${url}" ]; then
      (xdg-open "${url}" 2>/dev/null || open "${url}" 2>/dev/null) &
    fi
  fi
}

# ── First-run auto-setup ──────────────────────────────────────────────

first_run_setup() {
  # Vault structure
  if [ ! -d "${VAULT_DIR}" ]; then
    mkdir -p "${VAULT_DIR}/universal/developer"
    mkdir -p "${VAULT_DIR}/universal/patterns"
    mkdir -p "${VAULT_DIR}/universal/research"
    mkdir -p "${VAULT_DIR}/universal/content"
    mkdir -p "${VAULT_DIR}/projects"
  fi

  # Project team directory
  if [ ! -d "${TEAM_DIR}" ]; then
    mkdir -p "${TEAM_DIR}"
  fi

  # Project vault subdirectory
  local project_name
  project_name=$(detect_project_name)
  local project_vault="${VAULT_DIR}/projects/${project_name}"
  if [ ! -d "${project_vault}" ]; then
    mkdir -p "${project_vault}/architecture"
    mkdir -p "${project_vault}/qa-reviews"
    mkdir -p "${project_vault}/retros"
    mkdir -p "${project_vault}/decisions"
  fi

  # CODEOWNERS (if missing)
  if [ ! -f "${TEAM_DIR}/CODEOWNERS" ]; then
    cat > "${TEAM_DIR}/CODEOWNERS" << 'CODEOWNERS'
# brains-in-a-hat agent ownership mappings
# Format: <glob-pattern>  <agent-name>
# meta-retro updates this file during retrospectives.

*.qml                qt-qml
*.py                 architect
*.sql                data-schema
*.yml                devops
*.yaml               devops
*.json               data-schema
Dockerfile           packaging
*.spec               packaging
*.AppImage           packaging
*.md                 docs-writer
tests/               testing-strategy
.github/             devops
CODEOWNERS
  fi

  # Obsidian config (only if Obsidian is installed)
  if [ ! -d "${VAULT_DIR}/.obsidian" ]; then
    if command -v obsidian &>/dev/null || [ -d "${HOME}/.obsidian" ] || [ -d "${HOME}/.config/obsidian" ]; then
      mkdir -p "${VAULT_DIR}/.obsidian"
      cat > "${VAULT_DIR}/.obsidian/app.json" << 'OBSIDIAN'
{
  "promptDelete": false,
  "alwaysUpdateLinks": true,
  "newLinkFormat": "relative"
}
OBSIDIAN
    fi
  fi
}

# ── Project detection ─────────────────────────────────────────────────

detect_project_name() {
  local name
  name=$(gh repo view --json name -q '.name' 2>/dev/null || true)
  if [ -n "${name}" ]; then
    printf '%s' "${name}"
    return
  fi
  basename "$(pwd)"
}

# ── PM tier detection ─────────────────────────────────────────────────

detect_pm_tier() {
  local owner
  owner=$(gh repo view --json owner -q '.owner.login' 2>/dev/null || true)
  if [ -n "${owner}" ]; then
    local project_count
    project_count=$(gh project list --owner "${owner}" --format json --limit 1 2>/dev/null | jq '.projects | length' 2>/dev/null || echo "0")
    if [ "${project_count}" -gt 0 ] 2>/dev/null; then
      printf 'gh-project'
      return
    fi
  fi
  if gh issue list --limit 1 &>/dev/null 2>&1; then
    printf 'gh-issue'
    return
  fi
  printf 'local'
}

# ── Data gathering ────────────────────────────────────────────────────

gather_git_data() {
  local branch dirty recent_commits
  branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "not a git repo")
  dirty=$(git status --short 2>/dev/null || echo "")
  recent_commits=$(git log --oneline -5 2>/dev/null || echo "no commits")

  local ahead_behind=""
  if git rev-parse --abbrev-ref '@{upstream}' &>/dev/null; then
    ahead_behind=$(git rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null | awk '{print "behind:"$1" ahead:"$2}')
  fi

  printf 'Branch: %s\n' "${branch}"
  if [ -n "${ahead_behind}" ]; then
    printf 'Remote: %s\n' "${ahead_behind}"
  fi
  if [ -n "${dirty}" ]; then
    printf 'Dirty files:\n%s\n' "${dirty}"
  else
    printf 'Working tree: clean\n'
  fi
  printf 'Recent commits:\n%s\n' "${recent_commits}"
}

gather_issues() {
  local pm_tier="$1"
  case "${pm_tier}" in
    gh-project)
      local owner proj_num
      owner=$(gh repo view --json owner -q '.owner.login' 2>/dev/null || true)
      proj_num=$(gh project list --owner "${owner}" --format json --limit 1 2>/dev/null | jq -r '.projects[0].number' 2>/dev/null || true)
      if [ -n "${proj_num}" ] && [ "${proj_num}" != "null" ]; then
        gh project item-list "${proj_num}" --owner "${owner}" --limit 10 --format json 2>/dev/null | jq -r '.items[] | "- [\(.status)] \(.title)"' 2>/dev/null || echo "Could not read project items"
      else
        echo "No project found"
      fi
      ;;
    gh-issue)
      gh issue list --limit 10 --json number,title,labels --jq '.[] | "- #\(.number): \(.title)"' 2>/dev/null || echo "Could not read issues"
      ;;
    local)
      local project_name
      project_name=$(detect_project_name)
      local backlog="${VAULT_DIR}/projects/${project_name}/backlog.md"
      if [ -f "${backlog}" ]; then
        head -20 "${backlog}"
      else
        echo "No local backlog yet"
      fi
      ;;
  esac
}

gather_memory() {
  local encoded_path
  encoded_path=$(pwd | sed 's|/|-|g')
  local memory_dir="${HOME}/.claude/projects/${encoded_path}/memory/MEMORY.md"
  if [ -f "${memory_dir}" ]; then
    head -30 "${memory_dir}" 2>/dev/null || echo "No memory"
  else
    local name
    name=$(detect_project_name)
    local found
    found=$(find "${HOME}/.claude/projects/" -maxdepth 2 -name "MEMORY.md" -path "*${name}*" 2>/dev/null | head -1)
    if [ -n "${found}" ]; then
      head -30 "${found}" 2>/dev/null || echo "No memory"
    else
      echo "No project memory found"
    fi
  fi
}

gather_vault_state() {
  local project_name
  project_name=$(detect_project_name)
  local project_vault="${VAULT_DIR}/projects/${project_name}"

  local retro
  retro=$(ls -t "${project_vault}/retros/"*.md 2>/dev/null | head -1)
  if [ -n "${retro}" ]; then
    printf 'Last retro: %s\n' "$(basename "${retro}")"
    head -5 "${retro}" 2>/dev/null
  fi

  local persona="${VAULT_DIR}/universal/developer/persona.md"
  if [ -f "${persona}" ]; then
    printf '\nDeveloper persona:\n'
    head -10 "${persona}" 2>/dev/null
  fi

  local stakeholders="${project_vault}/stakeholders.md"
  if [ -f "${stakeholders}" ]; then
    printf '\nStakeholders:\n'
    head -10 "${stakeholders}" 2>/dev/null
  fi
}

# ── Build context ─────────────────────────────────────────────────────

build_context() {
  local project_name pm_tier

  project_name=$(detect_project_name)
  pm_tier=$(detect_pm_tier)

  # Cache PM tier
  mkdir -p "${TEAM_DIR}"
  printf '%s' "${pm_tier}" > "${TEAM_DIR}/pm-tier"

  local context=""
  context+="## Project: ${project_name}\n"
  context+="PM tier: ${pm_tier}\n"
  context+="Vault: ~/.claude/vault/projects/${project_name}/\n\n"

  context+="## Git State\n"
  context+="$(gather_git_data)\n\n"

  context+="## Backlog (${pm_tier})\n"
  context+="$(gather_issues "${pm_tier}")\n\n"

  context+="## Memory\n"
  context+="$(gather_memory)\n\n"

  context+="## Vault State\n"
  context+="$(gather_vault_state)\n\n"

  printf '%s' "${context}"
}

# ── JSON output ───────────────────────────────────────────────────────

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

main() {
  # Read hook input from stdin (contains session_id for greeting flag)
  local HOOK_INPUT
  HOOK_INPUT=$(cat)
  local SESSION_ID
  SESSION_ID=$(echo "$HOOK_INPUT" | jq -r '.session_id // empty' 2>/dev/null || true)

  # Launch dashboard (non-blocking)
  dashboard_start

  # Bootstrap vault and team dirs
  first_run_setup

  # Proactive greeting flag — consumed by UserPromptSubmit hook (first-prompt-greeting)
  if [ -n "${SESSION_ID}" ]; then
    touch "/tmp/neal-greeting-${SESSION_ID}"
  fi

  # Register project for dashboard multi-project discovery
  local project_name
  project_name=$(detect_project_name)
  local GLOBAL_SESSIONS="${HOME}/.claude/team/active-sessions.jsonl"
  mkdir -p "$(dirname "${GLOBAL_SESSIONS}")"
  jq -nc \
    --arg ts "$(date -Iseconds)" \
    --arg project "$(pwd)" \
    --arg name "${project_name}" \
    '{ts:$ts, project:$project, name:$name}' >> "${GLOBAL_SESSIONS}"

  # Read Neal persona
  local persona=""
  local persona_file="${PLUGIN_ROOT}/hooks/neal-persona.md"
  if [ -f "${persona_file}" ]; then
    persona=$(cat "${persona_file}")
  fi

  # Gather dynamic project context
  local dynamic_context
  dynamic_context=$(build_context)

  # Combine persona + dynamic context
  local full_context=""
  if [ -n "${persona}" ]; then
    full_context="${persona}\n\n--- SESSION CONTEXT ---\n\n${dynamic_context}"
  else
    full_context="${dynamic_context}"
  fi

  local escaped_context
  escaped_context=$(escape_for_json "${full_context}")

  # Output JSON for Claude Code hook system
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${escaped_context}"
  }
}
EOF
}

main
